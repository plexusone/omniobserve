    },
    "saturation": {
      "properties": {
        "metric": {
          "type": "string"
        },
        "unit": {
          "type": "string"
        },
        "golden_signal": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
