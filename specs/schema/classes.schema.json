{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/plexusone/omniobserve/specs/classes/service-spec",
  "properties": {
    "service": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "metrics_model": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "classes": {
      "items": {
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "slo_template": {
            "type": "string"
          },
          "endpoints": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "threshold_overrides": {
            "properties": {
              "latency": {
                "type": "string"
              },
              "availability": {
                "type": "number"
              },
              "error_rate": {
                "type": "number"
              },
              "time_window": {
                "type": "string"
              }
            },
            "additionalProperties": false,
            "type": "object"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "name",
          "slo_template",
          "endpoints"
        ]
      },
      "type": "array"
    },
    "default_class": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "type": "object",
  "required": [
    "service",
    "classes"
  ]
}